{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickPort",
  "version": "0.1.0",
  "identifier": "com.quickport.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "QuickPort",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "title": "QuickPort",
      "tooltip": "QuickPort — Amazon Quick companion for China ecosystem"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "One-click setup for Amazon Quick in China ecosystem",
    "longDescription": "QuickPort provides one-click installation and configuration of MCP servers for Feishu, DingTalk, and Chinese email providers. Includes a skill marketplace with security scanning, credential governance via OS Keychain, and PIPL-compliant audit logging.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "minimumSystemVersion": "10.0.0",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": false,
      "sidecar": true,
      "scope": [
        {
          "name": "node-mcp-server",
          "cmd": "node",
          "args": { "validator": "^.+$" }
        },
        {
          "name": "lark-cli",
          "cmd": "lark-cli",
          "args": { "validator": "^(auth|config|docs|im).*$" }
        }
      ]
    },
    "notification": {
      "all": true
    }
  }
}
