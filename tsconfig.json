{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@quickport/orchestrator/*": ["src/orchestrator/*"],
      "@quickport/orchestrator/quick-config-patcher/*": ["src/orchestrator/quick-config-patcher/*"],
      "@quickport/scanner/*": ["src/scanner/*"],
      "@quickport/installer/*": ["src/installer/*"],
      "@quickport/mcp/*": ["src/mcp/*"],
      "@quickport/ui/*": ["src/ui/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
